    <module name="insurance" />
    <option name="SPRING_BOOT_MAIN_CLASS" value="io.github.chubbyhippo.insurance.InsuranceApplication" />
    <option name="VM_PARAMETERS" value="-XX:StartFlightRecording=filename=./app.jfr,settings=profile,dumponexit=true" />
    <extension name="coverage">
      <pattern>
        <option name="PATTERN" value="io.github.chubbyhippo.insurance.*" />
        <option name="ENABLED" value="true" />
      </pattern>
    </extension>
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>